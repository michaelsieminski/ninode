{
	"name": "ninode",
	"version": "0.1.0",
	"description": "Terminal-based server monitoring built with React 19 and OpenTUI",
	"module": "src/index.tsx",
	"type": "module",
	"private": true,
	"bin": {
		"ninode": "dist/ninode"
	},
	"scripts": {
		"dev": "bun run --watch src/index.tsx",
		"build": "bun build --compile --minify --sourcemap src/index.tsx --outfile dist/ninode",
		"build:darwin-arm64": "bun build --compile --minify --sourcemap --target=bun-darwin-arm64 src/index.tsx --outfile dist/ninode-darwin-arm64",
		"build:linux-x64": "bun build --compile --minify --sourcemap --target=bun-linux-x64 src/index.tsx --outfile dist/ninode-linux-x64",
		"build:linux-arm64": "bun build --compile --minify --sourcemap --target=bun-linux-arm64 src/index.tsx --outfile dist/ninode-linux-arm64",
		"release": "bun run scripts/release.ts",
		"format": "biome format --write"
	},
	"dependencies": {
		"@napi-rs/keyring": "1.3.0",
		"@opentui/core": "0.2.10",
		"@opentui/react": "0.2.10",
		"react": "19.2.6",
		"ssh2": "1.17.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@types/bun": "1.3.14",
		"@types/ssh2": "1.15.5",
		"typescript": "6.0.3"
	}
}
